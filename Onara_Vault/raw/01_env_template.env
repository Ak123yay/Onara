# ============================================================
# ONARA — MASTER ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# Copy this file to .env.local (Next.js) and .env (FastAPI).
# Variables marked [NEXT] go in the Next.js root.
# Variables marked [FAST] go in the FastAPI pipeline server root.
# Variables marked [BOTH] go in both.
# Never commit either file to version control.
# ============================================================


# ------------------------------------------------------------
# GITHUB — App Deployer + Copilot SDK
# Setup: Steps 1.2, 1.3, 1.4
# ------------------------------------------------------------

# GitHub App numeric ID (shown at top of App settings page)
GITHUB_APP_ID=                          # [FAST] e.g. 123456

# Full contents of the downloaded .pem private key file
# Paste the entire key including BEGIN/END lines — use \n for newlines in Docker
GITHUB_APP_PRIVATE_KEY=                 # [FAST] -----BEGIN RSA PRIVATE KEY-----\n...

# Installation ID from URL: /settings/installations/{number}
GITHUB_APP_INSTALLATION_ID=            # [FAST] e.g. 78901234

# GitHub username that owns the onara-sites repo
GITHUB_REPO_OWNER=                      # [FAST] e.g. yourusername

# Always: onara-sites
GITHUB_REPO_NAME=onara-sites            # [FAST]

# Fine-grained PAT for GitHub Copilot SDK (Read-only Copilot permission only)
COPILOT_GITHUB_TOKEN=                   # [FAST] github_pat_...


# ------------------------------------------------------------
# GOOGLE
# Setup: Steps 1.5, 1.6, 1.7
# ------------------------------------------------------------

# Places API (New) key — restricted to Places API only
GOOGLE_PLACES_API_KEY=                  # [FAST] AIza...

# OAuth Client ID from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=                 # [NEXT] ...apps.googleusercontent.com

# OAuth Client Secret
GOOGLE_OAUTH_CLIENT_SECRET=            # [NEXT] GOCSPX-...


# ------------------------------------------------------------
# SUPABASE
# Setup: Step 2
# ------------------------------------------------------------

# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=              # [NEXT] https://xxxx.supabase.co

# Anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # [NEXT] eyJ...

# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=             # [NEXT] eyJ...

# Direct Postgres connection string (for migrations)
DATABASE_URL=                           # [NEXT] postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres


# ------------------------------------------------------------
# CLOUDFLARE PAGES
# Setup: Step 2, Step 22
# ------------------------------------------------------------

# Cloudflare account ID (shown in Workers & Pages > Overview, right sidebar)
CLOUDFLARE_ACCOUNT_ID=                  # [FAST] 32-char hex string

# API token with Cloudflare Pages:Edit permission
CLOUDFLARE_API_TOKEN=                   # [FAST] ...


# ------------------------------------------------------------
# STRIPE
# Setup: Step 2, Step 24
# ------------------------------------------------------------

# Secret key — server-side only
STRIPE_SECRET_KEY=                      # [NEXT] sk_live_... or sk_test_...

# Publishable key — safe for browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # [NEXT] pk_live_... or pk_test_...

# Webhook signing secret (from Stripe Dashboard > Webhooks > your endpoint)
STRIPE_WEBHOOK_SECRET=                  # [NEXT] whsec_...

# Price IDs from Stripe Dashboard > Products
STRIPE_PRICE_STARTER_MONTHLY=          # [NEXT] price_...
STRIPE_PRICE_PRO_MONTHLY=              # [NEXT] price_...
STRIPE_PRICE_STARTER_ANNUAL=           # [NEXT] price_...


# ------------------------------------------------------------
# RESEND (Email)
# Setup: Step 2
# ------------------------------------------------------------

# API key from Resend Dashboard
RESEND_API_KEY=                         # [NEXT] re_...

# Verified sender address (must match verified domain in Resend)
RESEND_FROM_EMAIL=hello@onara.tech      # [NEXT]

# Reply-to address for support replies
RESEND_REPLY_TO=support@onara.tech      # [NEXT]


# ------------------------------------------------------------
# NVIDIA NIM
# Setup: Step 2
# ------------------------------------------------------------

# Free NIM API key from build.nvidia.com
NVIDIA_NIM_API_KEY=                     # [FAST] nvapi-...

# Base URL — do not change unless NVIDIA updates it
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1   # [FAST]


# ------------------------------------------------------------
# OLLAMA (Local Models)
# Setup: Step 3
# ------------------------------------------------------------

# URL of your Ollama server — localhost during dev, DigitalOcean IP in prod
OLLAMA_BASE_URL=http://localhost:11434  # [FAST]

# Primary local model for agents 2, 3, 8, 10
OLLAMA_PRIMARY_MODEL=qwen3:8b           # [FAST]

# Fallback/supervisor model
OLLAMA_FALLBACK_MODEL=llama3.3:8b      # [FAST]


# ------------------------------------------------------------
# PIPELINE SERVER
# Setup: Step 15
# ------------------------------------------------------------

# URL where the FastAPI pipeline server is reachable from Next.js
# Dev:  use Cloudflare Tunnel URL (cloudflared tunnel --url http://localhost:8000)
# Prod: use DigitalOcean Droplet IP, e.g. http://164.90.xxx.xxx:8000
PIPELINE_SERVER_URL=                    # [NEXT] https://xxxx.trycloudflare.com

# Internal FastAPI port
PIPELINE_PORT=8000                      # [FAST]

# Shared secret to authenticate Next.js → FastAPI calls (generate a random 32-char string)
PIPELINE_API_SECRET=                    # [BOTH] openssl rand -hex 32

# Max concurrent pipeline jobs before queue starts
PIPELINE_MAX_CONCURRENCY=3             # [FAST]

# Hard timeout per job in seconds (5 minutes)
PIPELINE_JOB_TIMEOUT=300               # [FAST]


# ------------------------------------------------------------
# REDIS (Job Queue — Step 27 hardening, or from launch)
# Setup: Step 15 / Step 27
# ------------------------------------------------------------

# Redis connection URL — localhost in dev, Redis Cloud in prod
REDIS_URL=redis://localhost:6379        # [FAST]


# ------------------------------------------------------------
# CHROMADB (RAG Vector Store)
# Setup: Step 17
# ------------------------------------------------------------

# Filesystem path for persistent ChromaDB storage
CHROMA_PERSIST_PATH=./chroma_db        # [FAST]

# Collection name for the HTML/CSS/JS pattern library
CHROMA_COLLECTION_NAME=onara_patterns  # [FAST]


# ------------------------------------------------------------
# NEXT.JS APP
# Setup: Steps 9-14
# ------------------------------------------------------------

# Public base URL of the Onara Next.js app
NEXT_PUBLIC_APP_URL=https://onara.tech  # [NEXT]

# Used in absolute URLs for Stripe redirects, email links, etc.
APP_URL=https://onara.tech              # [NEXT]

# JWT secret for any custom tokens (separate from Supabase JWT)
NEXTAUTH_SECRET=                        # [NEXT] openssl rand -hex 32


# ------------------------------------------------------------
# FEATURE FLAGS
# Setup: as needed
# ------------------------------------------------------------

# Set to 'true' to enable Pro plan features (code download, priority queue)
FEATURE_CODE_DOWNLOAD=true             # [NEXT]

# Set to 'true' to show the Starter annual plan option
FEATURE_ANNUAL_PLAN=true               # [NEXT]

# Set to 'true' to enable GBP sync polling (v2.5 feature)
FEATURE_GBP_SYNC=false                 # [FAST]


# ------------------------------------------------------------
# MONITORING
# Setup: Step 28 / Step 25c
# ------------------------------------------------------------

# UptimeRobot webhook URL for alerts (optional but recommended)
UPTIME_ROBOT_WEBHOOK=                   # [FAST]

# PostHog public key for event analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=               # [NEXT] phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com  # [NEXT]


# ============================================================
# QUICK REFERENCE — Variable count by service
# GitHub:     6 variables
# Google:     3 variables
# Supabase:   4 variables
# Cloudflare: 2 variables
# Stripe:     5 variables
# Resend:     3 variables
# NVIDIA NIM: 2 variables
# Ollama:     3 variables
# Pipeline:   5 variables
# Redis:      1 variable
# ChromaDB:   2 variables
# Next.js:    3 variables
# Flags:      3 variables
# Monitoring: 3 variables
# TOTAL:      45 variables
# ============================================================
