# Onara FastAPI pipeline environment template
# Copy to: Onara_Code/pipeline/.env
# Keep .env private. Never commit real secrets.

# Supabase persistence
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional legacy alias. Prefer SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEY=

# App and API bridge
APP_URL=http://localhost:3000
PIPELINE_API_SECRET=
PIPELINE_PORT=8000
PIPELINE_MAX_CONCURRENCY=1
PIPELINE_JOB_TIMEOUT=600

# AI request behavior
AI_REQUEST_TIMEOUT=60
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY=0.5

# Google Places photo resolution
GOOGLE_PLACES_API_KEY=

# NVIDIA NIM
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Local Ollama
OLLAMA_BASE_URL=http://192.168.1.89:11434
OLLAMA_PRIMARY_MODEL=qwen3.5:9b
OLLAMA_FALLBACK_MODEL=gemma4:e4b

# ChromaDB / RAG
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=onara_patterns

# Cloudflare Pages deployment
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_PAGES_PROJECT_PREFIX=onara-site
CLOUDFLARE_WRANGLER_COMMAND=npx --yes wrangler

# GitHub App backup repository
GITHUB_API_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO_BRANCH=main
GITHUB_REPO_NAME=onara-sites
GITHUB_REPO_OWNER=

# GitHub Copilot SDK model route
COPILOT_GITHUB_TOKEN=
COPILOT_BASE_DIRECTORY=./.copilot_runtime

# Pipeline feature flags
FEATURE_GBP_SYNC=false
FEATURE_LEAD_EMAIL=true
