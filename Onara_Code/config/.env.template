# Onara — Environment Variables Template
# Copy this to .env.local (Next.js root) and .env (FastAPI root).
# Fill in values as you complete each Phase 1–3 setup task.
# NEVER commit the filled .env files — only this template is safe to commit.
#
# Status key: [PENDING] = not yet set up | [AUTO] = fixed value, do not change

# ─────────────────────────────────────────────
# GITHUB (Phase 1)
# Guide: wiki/dev/phase1-github-setup.md
# ─────────────────────────────────────────────
COPILOT_GITHUB_TOKEN=                        # [PENDING] Fine-grained PAT — Onara Copilot, read-only
GITHUB_REPO_OWNER=                           # [PENDING] Your GitHub username
GITHUB_REPO_NAME=onara-sites                 # [AUTO]
GITHUB_APP_ID=                               # [PENDING] Numeric ID from GitHub App settings page
GITHUB_APP_INSTALLATION_ID=                  # [PENDING] From /settings/installations/{id} URL
GITHUB_APP_PRIVATE_KEY=                      # [PENDING] Full .pem contents, newlines as \n

# ─────────────────────────────────────────────
# GOOGLE (Phase 1)
# Guide: wiki/integrations/google.md
# ─────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=                       # [PENDING] Restricted to Places API (New) only
GOOGLE_OAUTH_CLIENT_ID=                      # [PENDING] OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_SECRET=                  # [PENDING] OAuth 2.0 Client Secret

# ─────────────────────────────────────────────
# SUPABASE (Phase 2)
# Guide: wiki/integrations/supabase.md
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=                    # [PENDING] https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=               # [PENDING] eyJ... — safe for browser
SUPABASE_SERVICE_ROLE_KEY=                   # [PENDING] eyJ... — server-side only, never expose
DATABASE_URL=                                # [PENDING] postgres://... for migrations

# ─────────────────────────────────────────────
# CLOUDFLARE (Phase 2)
# Guide: wiki/integrations/cloudflare.md
# ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=                       # [PENDING] 32-char hex from Pages dashboard
CLOUDFLARE_API_TOKEN=                        # [PENDING] Token with Cloudflare Pages:Edit permission

# ─────────────────────────────────────────────
# STRIPE (Phase 2)
# Guide: wiki/integrations/stripe.md
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=                           # [PENDING] sk_test_... (keep test key until pre-launch)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=          # [PENDING] pk_test_...
STRIPE_WEBHOOK_SECRET=                       # [PENDING] whsec_...
STRIPE_FREE_PRICE_ID=                        # [PENDING] optional $0 placeholder price
STRIPE_STARTER_PRICE_ID=                     # [PENDING] price_... for $12/month
STRIPE_STARTER_ANNUAL_PRICE_ID=              # [PENDING] price_... for $99/year
STRIPE_PRO_PRICE_ID=                         # [PENDING] price_... for $29/month

# ─────────────────────────────────────────────
# RESEND (Phase 2)
# Guide: wiki/integrations/resend.md
# ─────────────────────────────────────────────
RESEND_API_KEY=                              # [PENDING] re_...
RESEND_FROM_EMAIL=hello@onara.tech           # [AUTO]
RESEND_REPLY_TO=support@onara.tech           # [AUTO]

# ─────────────────────────────────────────────
# NVIDIA NIM (Phase 2 — free tier)
# Guide: wiki/integrations/nvidia-nim.md
# ─────────────────────────────────────────────
NVIDIA_NIM_API_KEY=                          # [PENDING] nvapi-... from build.nvidia.com
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1  # [AUTO]

# ─────────────────────────────────────────────
# OLLAMA (Phase 2 — local install)
# Guide: wiki/integrations/ollama.md
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434        # [AUTO] Change to server IP in prod
OLLAMA_PRIMARY_MODEL=qwen3.5:9b              # [AUTO]
OLLAMA_FALLBACK_MODEL=gemma4:e4b             # [AUTO]

# ─────────────────────────────────────────────
# PIPELINE (Phase 3 — set after cloudflared runs)
# ─────────────────────────────────────────────
PIPELINE_SERVER_URL=                         # [PENDING] Cloudflare Tunnel URL
PIPELINE_PORT=8000                           # [AUTO]
PIPELINE_API_SECRET=                         # [PENDING] Generate: openssl rand -hex 32
PIPELINE_MAX_CONCURRENCY=1                   # [AUTO] use 1 for local Ollama dev; raise only after load testing
PIPELINE_JOB_TIMEOUT=300                     # [AUTO]

# ─────────────────────────────────────────────
# SUPABASE EDGE FUNCTIONS (Phase 6)
# ─────────────────────────────────────────────
CRON_SECRET=                                 # [PENDING] Bearer token for scheduled Edge Function calls

# ─────────────────────────────────────────────
# CHROMADB (Phase 5 — RAG system)
# ─────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_db             # [AUTO]
CHROMA_COLLECTION_NAME=onara_patterns        # [AUTO]

# ─────────────────────────────────────────────
# NEXT.JS APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://onara.tech       # [AUTO] Use http://localhost:3000 for local dev
APP_URL=https://onara.tech                   # [AUTO]
NEXTAUTH_SECRET=                             # [PENDING] Generate: openssl rand -hex 32

# ─────────────────────────────────────────────
# MONITORING (Phase 4)
# ─────────────────────────────────────────────
UPTIME_ROBOT_WEBHOOK=                        # [PENDING] From UptimeRobot alert settings
NEXT_PUBLIC_POSTHOG_KEY=                     # [PENDING] From PostHog project settings
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com  # [AUTO]

# ─────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────
FEATURE_CODE_DOWNLOAD=true                   # Pro plan: enable HTML/CSS/JS download
FEATURE_ANNUAL_PLAN=true                     # Show Starter annual billing option
FEATURE_GBP_SYNC=false                       # v2.5 only — keep false at launch
FEATURE_REVIEWS_BADGE=true                   # v1: weekly reviews badge refresh
FEATURE_LEAD_SMS=true                        # v1: Twilio SMS on contact form submit
