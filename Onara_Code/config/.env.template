# Onara combined environment template
# Use this as the master checklist for local, server, and Supabase Edge Function secrets.
# Copy relevant values into:
# - Onara_Code/app/.env.local
# - Onara_Code/pipeline/.env
# - Supabase secrets via "supabase secrets set KEY=value ..."
# Never commit filled env files or real secret values.

# -----------------------------------------------------------------------------
# Next.js app: Onara_Code/app/.env.local
# -----------------------------------------------------------------------------

# Supabase app/auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional legacy alias. Prefer SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google Places proxy
GOOGLE_PLACES_API_KEY=

# Google OAuth values are configured in Supabase Auth.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# FastAPI pipeline bridge
PIPELINE_SERVER_URL=http://localhost:8000
PIPELINE_API_SECRET=

# Cloudflare dashboard cleanup/suspension
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# GitHub App backup/download repository
GITHUB_API_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO_BRANCH=main
GITHUB_REPO_NAME=onara-sites
GITHUB_REPO_OWNER=

# Stripe billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Next.js feature flags
FEATURE_CODE_DOWNLOAD=true

# -----------------------------------------------------------------------------
# FastAPI pipeline server: Onara_Code/pipeline/.env
# -----------------------------------------------------------------------------

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=http://localhost:3000
PIPELINE_API_SECRET=
PIPELINE_PORT=8000
PIPELINE_MAX_CONCURRENCY=1
PIPELINE_JOB_TIMEOUT=300

AI_REQUEST_TIMEOUT=60
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY=0.5

GOOGLE_PLACES_API_KEY=

NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

OLLAMA_BASE_URL=http://192.168.1.89:11434
OLLAMA_PRIMARY_MODEL=qwen3.5:9b
OLLAMA_FALLBACK_MODEL=gemma4:e4b

CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=onara_patterns

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_PAGES_PROJECT_PREFIX=onara-site
CLOUDFLARE_WRANGLER_COMMAND=npx --yes wrangler

GITHUB_API_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO_BRANCH=main
GITHUB_REPO_NAME=onara-sites
GITHUB_REPO_OWNER=

COPILOT_GITHUB_TOKEN=
COPILOT_BASE_DIRECTORY=./.copilot_runtime

FEATURE_GBP_SYNC=false
FEATURE_LEAD_EMAIL=true

