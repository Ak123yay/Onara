# Copy this file to .env.local for local Next.js development.
# Keep .env.local private. Never commit real secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google
GOOGLE_PLACES_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# FastAPI pipeline
PIPELINE_SERVER_URL=http://localhost:8000
PIPELINE_API_SECRET=

# Cloudflare Pages cleanup and reviews badge refresh
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_PAGES_PROJECT_PREFIX=onara-site

# GitHub backup/download repository
GITHUB_API_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO_BRANCH=main
GITHUB_REPO_NAME=onara-sites
GITHUB_REPO_OWNER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@onara.tech
RESEND_REPLY_TO=support@onara.tech

# App URLs and auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Feature flags
FEATURE_CODE_DOWNLOAD=true
FEATURE_ANNUAL_PLAN=false
FEATURE_REVIEWS_BADGE=true
FEATURE_LEAD_EMAIL=false
FEATURE_GBP_SYNC=false
