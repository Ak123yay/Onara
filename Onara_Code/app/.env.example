# Onara Next.js app environment template
# Copy to: Onara_Code/app/.env.local
# Keep .env.local private. Never commit real secrets.

# Supabase app/auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional legacy alias. Prefer SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google Places proxy
GOOGLE_PLACES_API_KEY=

# Google OAuth values are configured in Supabase Auth, not read directly by Next.js.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# FastAPI pipeline bridge
PIPELINE_SERVER_URL=http://localhost:8000
PIPELINE_API_SECRET=

# Cloudflare cleanup from dashboard delete/suspend actions
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# GitHub App backup/download repository
GITHUB_API_URL=https://api.github.com
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO_BRANCH=main
GITHUB_REPO_NAME=onara-sites
GITHUB_REPO_OWNER=

# Stripe billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_CUSTOM_DOMAIN_PRICE_ID=

# Next.js feature flags
FEATURE_CODE_DOWNLOAD=true
FEATURE_CUSTOM_DOMAIN=true

# Supabase Edge Function secrets.
# Set these with "supabase secrets set"; they are listed here so launch envs stay complete.
SUPABASE_URL=https://your-project.supabase.co
CRON_SECRET=
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_PAGES_PROJECT_PREFIX=onara-site
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@onara.tech
RESEND_REPLY_TO=support@onara.tech
RESEND_WEBHOOK_SECRET=
SUPPORT_EMAIL_WEBHOOK_SECRET=
SUPPORT_FROM_EMAIL="Onara Support <support@onara.tech>"
SUPPORT_FORWARD_TO=
FEATURE_SUPPORT_AI_RESPONDER=true
SUPPORT_AI_MODEL=z-ai/glm-5.1
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
FEATURE_REVIEWS_BADGE=true
FEATURE_LEAD_EMAIL=true
FEATURE_GBP_SYNC=false
FEATURE_CUSTOM_DOMAIN=true
